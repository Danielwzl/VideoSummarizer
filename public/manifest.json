{
  "manifest_version": 3,
  "name": "YouTube Transcript Summarizer",
  "version": "1.0.0",
  "description": "Extract YouTube video transcripts and summarize with DeepSeek AI",
  "permissions": ["activeTab", "storage", "sidePanel"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://api.deepseek.com/*"
  ],
  "action": {
    "default_title": "YouTube Transcript Summarizer"
  },
  "side_panel": {
    "default_path": "popup/index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
